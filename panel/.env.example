APP_NAME=Hostvim
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
# Yerel sanal host: deploy/host/apache-hostvim-xampp.conf — http://hostvim.local
APP_URL=http://hostvim.local

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Admin/vendor için zorunlu 2FA politikası (false: isteğe bağlı; true: 2FA açık hesaplarda yönetici API’leri OTP token ister)
ENFORCE_ADMIN_2FA=false

ENGINE_API_URL=http://127.0.0.1:9090
ENGINE_INTERNAL_KEY=hostvim-engine-internal-dev
# Engine security.jwt_secret ile aynı (web terminal JWT); boşsa terminal kapalı
ENGINE_API_SECRET=

# İsteğe bağlı Cloudflare önbellek temizliği (CdnIntegrationService — çok kiracılı ortamda dikkat: zone genelidir)
# HOSTVIM_CDN_PROVIDER=cloudflare
# HOSTVIM_CDN_API_TOKEN=
# HOSTVIM_CDN_ZONE_ID=

# Let’s Encrypt için ACME e-postası (panel isteğinde yoksa engine `hosting.lets_encrypt_email` kullanılır)
# HOSTVIM_LETS_ENCRYPT_EMAIL=

# Engine ile aynı dizin: proje kökü/data/www (boş bırakılırsa otomatik)
# HOSTVIM_HOSTING_WEB_ROOT=

# Dosya yöneticisi tek dosya üst sınırı (MB). PHP upload_max_filesize ve post_max_size bu değerden büyük olmalı (multipart payı için + birkaç MB).
# HOSTVIM_MAX_FILE_MANAGER_SIZE_MB=50

# Veritabanları sayfası — canlıda tam URL verin
# PHPMYADMIN_URL=https://mysql.example.com/phpmyadmin
# ADMINER_URL=https://db.example.com/adminer.php

# XAMPP MySQL: gerçek CREATE DATABASE / kullanıcı (panel .env’deki DB_* ayrı kalır)
MYSQL_PROVISION_ENABLED=false
MYSQL_PROVISION_HOST=127.0.0.1
MYSQL_PROVISION_PORT=3306
MYSQL_PROVISION_USERNAME=root
MYSQL_PROVISION_PASSWORD=
MYSQL_PROVISION_GRANT_HOST=localhost
# MySQL kullanıcı @host için virgülle ayrılmış sabit değerler (ek olarak herhangi bir IPv4/IPv6 da kabul edilir)
# MYSQL_ALLOWED_GRANT_HOSTS=localhost,127.0.0.1,%

# PostgreSQL provizyon (pdo_pgsql)
# POSTGRES_PROVISION_ENABLED=false
# POSTGRES_PROVISION_HOST=127.0.0.1
# POSTGRES_PROVISION_PORT=5432
# POSTGRES_PROVISION_USERNAME=postgres
# POSTGRES_PROVISION_PASSWORD=
# POSTGRES_PROVISION_ADMIN_DB=postgres

# Merkezi lisans hub’ı. Satırı silerseniz varsayılan https://hostvim.com kullanılır; müşteri ek ayar yapmaz.
# Tamamen kapatmak için: LICENSE_SERVER_URL=
# LICENSE_SERVER_URL=
# İsteğe bağlı Bearer (landing HOSTVIM_LICENSE_API_SECRET ile aynı)
# LICENSE_SERVER_API_SECRET=
# İsteğe bağlı otomasyon; müşteri çoğunlukla Admin → Lisans’tan yapıştırır
# LICENSE_KEY=

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

PANEL_DEFAULT_LOCALE=en
PANEL_AVAILABLE_LOCALES=en,tr,de,fr,es,pt,zh,ja,ar,ru
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
