# Hostvim panel — üretim şablonu (install-production.sh bunu .env olarak kopyalar)
# Canlıda APP_URL ve ENGINE_INTERNAL_KEY /etc/hostvim/engine.yaml ile aynı olmalı.

APP_NAME=Hostvim
APP_ENV=production
APP_PROFILE=customer
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://panel.ornek.com
# Tarayıcıdan hangi host/IP ile giriliyorsa APP_URL ile aynı olmalı (vendor API host denetimi APP_URL’den türetilir).
# Örnek: http://194.163.131.213 — VENDOR_PORTAL_HOSTS boşsa bu host kullanılır.
# İsteğe bağlı açık liste: VENDOR_PORTAL_HOSTS=panel.ornek.com,194.163.131.213

APP_LOCALE=tr
APP_FALLBACK_LOCALE=en

ENGINE_API_URL=http://127.0.0.1:9090
ENGINE_INTERNAL_KEY=KURULUM_BETIGI_URETIR
# Engine security.jwt_secret ile aynı (web terminal JWT); boşsa terminal kapalı
ENGINE_API_SECRET=

# Panel veritabanı (install-production.sh WITH_MARIADB=1 ile doldurulur)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hostvim
DB_USERNAME=hostvim
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

LOG_CHANNEL=stack
LOG_LEVEL=error

QUEUE_CONNECTION=database
CACHE_STORE=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Giden posta: kurulumda Postfix ile sendmail önerilir; SMTP/hosting sağlayıcı için Admin → Giden posta
MAIL_MAILER=sendmail
MAIL_FROM_ADDRESS="noreply@ornek.com"
MAIL_FROM_NAME="${APP_NAME}"
# MAIL_HOST= MAIL_PORT=587 MAIL_USERNAME= MAIL_PASSWORD= MAIL_ENCRYPTION=tls

PANEL_DEFAULT_LOCALE=tr
PANEL_AVAILABLE_LOCALES=en,tr,de,fr,es

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

LICENSE_SERVER_URL=https://license.hostvim.com
LICENSE_KEY=

# Vendor kontrol düzlemi (/api/vendor/*). Açıkken migrate + seed vendor rolleri gerekir.
# VENDOR_ENABLED=true
# APP_PROFILE=vendor   # frontend build: AdminVendorControl vb. (install-production.sh APP_PROFILE ile VITE_APP_PROFILE geçer)

MYSQL_PROVISION_ENABLED=true
MYSQL_PROVISION_HOST=127.0.0.1
MYSQL_PROVISION_PORT=3306
MYSQL_PROVISION_USERNAME=root
MYSQL_PROVISION_PASSWORD=
MYSQL_PROVISION_GRANT_HOST=localhost
