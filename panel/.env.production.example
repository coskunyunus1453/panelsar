# Panelsar panel — üretim şablonu (install-production.sh bunu .env olarak kopyalar)
# Canlıda APP_URL ve ENGINE_INTERNAL_KEY /etc/panelsar/engine.yaml ile aynı olmalı.

APP_NAME=Panelsar
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://panel.ornek.com

APP_LOCALE=tr
APP_FALLBACK_LOCALE=en

ENGINE_API_URL=http://127.0.0.1:9090
ENGINE_INTERNAL_KEY=KURULUM_BETIGI_URETIR
# Engine security.jwt_secret ile aynı (web terminal JWT); boşsa terminal kapalı
ENGINE_API_SECRET=

# Panel veritabanı (install-production.sh WITH_MARIADB=1 ile doldurulur)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=panelsar
DB_USERNAME=panelsar
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

LOG_CHANNEL=stack
LOG_LEVEL=error

QUEUE_CONNECTION=database
CACHE_STORE=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@ornek.com"
MAIL_FROM_NAME="${APP_NAME}"

PANEL_DEFAULT_LOCALE=tr
PANEL_AVAILABLE_LOCALES=en,tr,de,fr,es

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

LICENSE_SERVER_URL=https://license.panelsar.com
LICENSE_KEY=

MYSQL_PROVISION_ENABLED=true
MYSQL_PROVISION_HOST=127.0.0.1
MYSQL_PROVISION_PORT=3306
MYSQL_PROVISION_USERNAME=root
MYSQL_PROVISION_PASSWORD=
MYSQL_PROVISION_GRANT_HOST=localhost
