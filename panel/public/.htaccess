Options -MultiViews

# mod_php: yükleme 413 — php.ini veya sanal hostta php_admin_value ile de artırılabilir (XAMPP: deploy/host/apache-hostvim-xampp.conf).
<IfModule php_module>
    php_value upload_max_filesize 128M
    php_value post_max_size 128M
</IfModule>
<IfModule mod_php.c>
    php_value upload_max_filesize 128M
    php_value post_max_size 128M
</IfModule>

RewriteEngine On

# Apache/mod_php bazen `Authorization` header’ını PHP’ye iletmez.
# Laravel sanctum `Authorization: Bearer <token>` beklediği için burada forward ediyoruz.
RewriteCond %{HTTP:Authorization} .
RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Var olan dosya/klasörler direkt servis edilir.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SPA refresh sırasında (örn: /admin/packages) React'in index.html'ini servis et.
# API çağrılarımız `index.php/api/...` formunda olduğu için onları bu fallback'den dışarıda bırakıyoruz.
RewriteCond %{REQUEST_URI} !^/index\.php/ [NC]

RewriteRule ^ index.html [L]

