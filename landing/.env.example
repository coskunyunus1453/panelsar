APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Ön yüz /storage (hero görseli vb.) için: proje kökünde `php artisan storage:link` çalıştırın.
#
# Siteyi alt klasörden açıyorsanız (örn. http://localhost/hostvim/landing/public/):
# 1) APP_URL tam taban adres (sonunda / olmasın):
#    APP_URL=http://localhost/hostvim/landing/public
# 2) Vite / admin-editor preload yolları için (npm run build ÖNCESİ .env'de, tırnaksız yol):
#    ASSET_URL=/hostvim/landing/public
#    Sonra: npm run build

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# SQLite: use absolute path if Apache/cli resolve different base paths (e.g. XAMPP)
# DB_DATABASE=/path/to/project/database/database.sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=

# file = no DB writes per request; database = needs database/*.sqlite writable by web server
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
# Üretimde HTTPS kullanıyorsanız: SESSION_SECURE_COOKIE=true (oturum çerezini yalnızca güvenli kanala bağlar)
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
