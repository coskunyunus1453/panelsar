APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Ön yüz /storage (hero görseli vb.) için: proje kökünde `php artisan storage:link` çalıştırın.
#
# Siteyi alt klasörden açıyorsanız (örn. https://localhost/hostvim/landing/public):
# 1) APP_URL ile tarayıcıdaki kök birebir aynı olsun (sonunda / yok):
#    APP_URL=https://localhost/hostvim/landing/public
# 2) Vite: derleme sırasında base path; BOŞ bırakılırsa JS /build/... isteğini
#    site kökünden (https://localhost/build/...) açar → 404 ve Quill yüklenmez.
#    Alt klasör yolu, başında ve sonunda / olmadan veya uyumlu şekilde:
#    ASSET_URL=https://localhost/hostvim/landing/public
#    veya: ASSET_URL=/hostvim/landing/public
# 3) .env kaydet → npm run build → php artisan config:clear

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Merkezi lisans API: POST /api/v1/license/validate — doluysa Bearer zorunlu (panel LICENSE_SERVER_API_SECRET ile aynı)
# HOSTVIM_LICENSE_API_SECRET=

# Perakende lisans ödemesi (landing): locale tr → PayTR, diğer → Stripe (HOSTVIM_BILLING_FORCE_PROVIDER ile sabitlenebilir)
# HOSTVIM_BILLING_DEFAULT=auto
# HOSTVIM_BILLING_FORCE_PROVIDER=
# HOSTVIM_BILLING_TR_LOCALES=tr

# PayTR (Bildirim URL: {APP_URL}/api/v1/webhooks/paytr-licensing)
# PAYTR_MERCHANT_ID=
# PAYTR_MERCHANT_KEY=
# PAYTR_MERCHANT_SALT=
# PAYTR_TEST_MODE=0
# PAYTR_DEBUG_ON=0

# Stripe Checkout + webhook (olay: checkout.session.completed → {APP_URL}/api/v1/webhooks/stripe-licensing)
# STRIPE_SECRET=
# STRIPE_WEBHOOK_SECRET=

# Lisans e-postası için MAIL_* ayarları (log sürücüsünde e-posta gitmez)

DB_CONNECTION=sqlite
# SQLite: use absolute path if Apache/cli resolve different base paths (e.g. XAMPP)
# DB_DATABASE=/path/to/project/database/database.sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=

# file = no DB writes per request; database = needs database/*.sqlite writable by web server
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
# Üretimde HTTPS kullanıyorsanız: SESSION_SECURE_COOKIE=true (oturum çerezini yalnızca güvenli kanala bağlar)
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# XAMPP: file cache `storage/framework/cache` gerektirir; Apache (daemon) yazamıyorsa array kullanın veya storage sahipliğini düzeltin.
CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
