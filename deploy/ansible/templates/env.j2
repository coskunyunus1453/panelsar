APP_NAME=Hostvim
APP_ENV=production
APP_DEBUG=false
APP_URL={{ app_url | default('https://panel.example.com') }}
APP_KEY={{ vault_app_key }}

DB_CONNECTION=mysql
DB_HOST={{ vault_db_host | default('127.0.0.1') }}
DB_PORT=3306
DB_DATABASE={{ vault_db_database }}
DB_USERNAME={{ vault_db_username }}
DB_PASSWORD={{ vault_db_password }}

ENGINE_API_URL={{ vault_engine_url | default('http://127.0.0.1:9090') }}
ENGINE_INTERNAL_KEY={{ vault_engine_internal_key }}
HOSTVIM_HOSTING_WEB_ROOT={{ hosting_web_root | default('/var/www/data/www') }}

MYSQL_PROVISION_ENABLED={{ mysql_provision_enabled | default('true') }}
MYSQL_PROVISION_HOST={{ vault_mysql_provision_host | default('127.0.0.1') }}
MYSQL_PROVISION_USERNAME={{ vault_mysql_provision_user }}
MYSQL_PROVISION_PASSWORD={{ vault_mysql_provision_password }}

PHPMYADMIN_URL={{ phpmyadmin_url | default('') }}
