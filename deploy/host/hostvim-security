#!/bin/bash
# Hostvim engine (www-data) tarafından sudo ile çağrılır.
set -euo pipefail

ACTION="${1:-}"
ARG1="${2:-}"
ARG2="${3:-}"
ARG3="${4:-}"

service_exists() {
  local svc="$1"
  systemctl list-unit-files --type=service 2>/dev/null | awk '{print $1}' | grep -qx "${svc}.service"
}

service_active() {
  local svc="$1"
  if systemctl is-active --quiet "$svc"; then
    echo "enabled"
  else
    echo "disabled"
  fi
}

sanitize_mod_name() {
  local m="$1"
  [[ "$m" =~ ^[a-zA-Z0-9_]+$ ]] || return 1
  echo "$m"
}

nginx_scope_path() {
  local scope="$1"
  case "$scope" in
    main) echo "/etc/nginx/nginx.conf" ;;
    panel) echo "/etc/nginx/sites-available/hostvim.conf" ;;
    *) return 1 ;;
  esac
}

sanitize_domain() {
  local d="$1"
  [[ "$d" =~ ^[A-Za-z0-9.-]+\.[A-Za-z]{2,}$ ]] || return 1
  [[ "$d" != .* && "$d" != *..* ]] || return 1
  echo "$d"
}

case "$ACTION" in
  fail2ban-jail-get)
    CONF="/etc/fail2ban/jail.local"
    if [[ ! -f "$CONF" ]]; then
      echo "bantime=600 findtime=600 maxretry=5"
      exit 0
    fi
    B="$(awk -F= '/^[[:space:]]*bantime[[:space:]]*=/{gsub(/[[:space:]]/, "", $2); print $2; exit}' "$CONF")"
    F="$(awk -F= '/^[[:space:]]*findtime[[:space:]]*=/{gsub(/[[:space:]]/, "", $2); print $2; exit}' "$CONF")"
    M="$(awk -F= '/^[[:space:]]*maxretry[[:space:]]*=/{gsub(/[[:space:]]/, "", $2); print $2; exit}' "$CONF")"
    [[ "$B" =~ ^[0-9]+$ ]] || B=600
    [[ "$F" =~ ^[0-9]+$ ]] || F=600
    [[ "$M" =~ ^[0-9]+$ ]] || M=5
    echo "bantime=$B findtime=$F maxretry=$M"
    ;;
  fail2ban-jail-set)
    B="$ARG1"; F="$ARG2"; M="$ARG3"
    [[ "$B" =~ ^[0-9]+$ ]] || { echo "invalid bantime" >&2; exit 1; }
    [[ "$F" =~ ^[0-9]+$ ]] || { echo "invalid findtime" >&2; exit 1; }
    [[ "$M" =~ ^[0-9]+$ ]] || { echo "invalid maxretry" >&2; exit 1; }
    [[ "$B" -ge 60 && "$B" -le 604800 ]] || { echo "bantime out of range" >&2; exit 1; }
    [[ "$F" -ge 60 && "$F" -le 604800 ]] || { echo "findtime out of range" >&2; exit 1; }
    [[ "$M" -ge 1 && "$M" -le 20 ]] || { echo "maxretry out of range" >&2; exit 1; }
    CONF="/etc/fail2ban/jail.local"
    cat > "$CONF" <<EOF
[DEFAULT]
bantime = $B
findtime = $F
maxretry = $M

[sshd]
enabled = true

[hostvim-auth]
enabled = true
EOF
    chmod 644 "$CONF"
    systemctl restart fail2ban || true
    echo "ok"
    ;;
  fail2ban-status)
    service_exists "fail2ban" || { echo "disabled"; exit 0; }
    service_active "fail2ban"
    ;;
  fail2ban-set)
    [[ "$ARG1" == "on" || "$ARG1" == "off" ]] || { echo "invalid state" >&2; exit 1; }
    if ! service_exists "fail2ban"; then
      if [[ "$ARG1" == "off" ]]; then
        echo "disabled"
        exit 0
      fi
      export DEBIAN_FRONTEND=noninteractive
      apt-get update -y >/dev/null
      apt-get install -y fail2ban >/dev/null
      systemctl enable --now fail2ban >/dev/null 2>&1 || true
      service_exists "fail2ban" || { echo "fail2ban install failed" >&2; exit 1; }
    fi
    if [[ "$ARG1" == "on" ]]; then
      systemctl enable --now fail2ban
    else
      systemctl disable --now fail2ban
    fi
    service_active "fail2ban"
    ;;
  fail2ban-install)
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -y >/dev/null
    apt-get install -y fail2ban >/dev/null
    systemctl enable --now fail2ban >/dev/null 2>&1 || true
    service_exists "fail2ban" || { echo "fail2ban install failed" >&2; exit 1; }
    echo "installed"
    ;;
  clamav-status)
    if systemctl is-active --quiet clamav-daemon || systemctl is-active --quiet clamav-freshclam; then
      echo "enabled"
    else
      echo "disabled"
    fi
    ;;
  clamav-set)
    [[ "$ARG1" == "on" || "$ARG1" == "off" ]] || { echo "invalid state" >&2; exit 1; }
    if ! service_exists "clamav-daemon" && ! service_exists "clamav-freshclam"; then
      echo "clamav services not installed" >&2
      exit 1
    fi
    if [[ "$ARG1" == "on" ]]; then
      systemctl enable --now clamav-freshclam || true
      systemctl enable --now clamav-daemon || true
    else
      systemctl disable --now clamav-daemon || true
      systemctl disable --now clamav-freshclam || true
    fi
    if systemctl is-active --quiet clamav-daemon || systemctl is-active --quiet clamav-freshclam; then
      echo "enabled"
    else
      echo "disabled"
    fi
    ;;
  clamav-scan)
    TARGET="${ARG1:-/var/www}"
    [[ "$TARGET" == /* ]] || { echo "target must be absolute path" >&2; exit 1; }
    [[ -d "$TARGET" ]] || { echo "scan target not found: $TARGET" >&2; exit 1; }
    clamscan -ri --stdout "$TARGET"
    ;;
  modsec-status)
    CONF=""
    for C in /etc/modsecurity/modsecurity.conf /etc/apache2/mods-available/security2.conf /etc/httpd/conf.d/mod_security.conf; do
      if [[ -f "$C" ]]; then CONF="$C"; break; fi
    done
    if [[ -n "$CONF" ]] && grep -Eq '^\s*SecRuleEngine\s+On\b' "$CONF"; then
      echo "enabled"
    else
      echo "disabled"
    fi
    ;;
  modsec-set)
    [[ "$ARG1" == "on" || "$ARG1" == "off" ]] || { echo "invalid state" >&2; exit 1; }
    CONF=""
    for C in /etc/modsecurity/modsecurity.conf /etc/apache2/mods-available/security2.conf /etc/httpd/conf.d/mod_security.conf; do
      if [[ -f "$C" ]]; then CONF="$C"; break; fi
    done
    if [[ -z "$CONF" ]]; then
      if [[ "$ARG1" == "off" ]]; then
        echo "disabled"
        exit 0
      fi
      export DEBIAN_FRONTEND=noninteractive
      apt-get update -y >/dev/null
      apt-get install -y libapache2-mod-security2 modsecurity-crs >/dev/null
      if command -v a2enmod >/dev/null 2>&1; then
        a2enmod security2 >/dev/null 2>&1 || true
      fi
      CONF=""
      for C in /etc/modsecurity/modsecurity.conf /etc/apache2/mods-available/security2.conf /etc/httpd/conf.d/mod_security.conf; do
        if [[ -f "$C" ]]; then CONF="$C"; break; fi
      done
      [[ -n "$CONF" ]] || { echo "missing modsecurity config file after install" >&2; exit 1; }
    fi
    if [[ "$ARG1" == "on" ]]; then
      sed -i -E 's/^\s*SecRuleEngine\s+.*/SecRuleEngine On/' "$CONF"
    else
      sed -i -E 's/^\s*SecRuleEngine\s+.*/SecRuleEngine Off/' "$CONF"
    fi
    systemctl reload apache2 || true
    if grep -Eq '^\s*SecRuleEngine\s+On\b' "$CONF"; then
      echo "enabled"
    else
      echo "disabled"
    fi
    ;;
  modsec-install)
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -y >/dev/null
    apt-get install -y libapache2-mod-security2 modsecurity-crs >/dev/null
    if command -v a2enmod >/dev/null 2>&1; then
      a2enmod security2 >/dev/null 2>&1 || true
    fi
    CONF=""
    for C in /etc/modsecurity/modsecurity.conf /etc/apache2/mods-available/security2.conf /etc/httpd/conf.d/mod_security.conf; do
      if [[ -f "$C" ]]; then CONF="$C"; break; fi
    done
    [[ -n "$CONF" ]] || { echo "missing modsecurity config file" >&2; exit 1; }
    sed -i -E 's/^\s*SecRuleEngine\s+.*/SecRuleEngine On/' "$CONF" || true
    systemctl reload apache2 >/dev/null 2>&1 || true
    echo "installed"
    ;;
  apache-modules-list)
    for f in /etc/apache2/mods-available/*.load; do
      [[ -f "$f" ]] || continue
      mod="$(basename "$f" .load)"
      if a2query -m "$mod" 2>/dev/null | grep -q "enabled"; then
        echo "$mod enabled"
      else
        echo "$mod disabled"
      fi
    done
    ;;
  apache-module-set)
    MOD="$(sanitize_mod_name "$ARG1")" || { echo "invalid module name" >&2; exit 1; }
    [[ "$ARG2" == "on" || "$ARG2" == "off" ]] || { echo "invalid state" >&2; exit 1; }
    [[ -f "/etc/apache2/mods-available/${MOD}.load" ]] || { echo "module not found: $MOD" >&2; exit 1; }
    if [[ "$ARG2" == "on" ]]; then
      a2enmod "$MOD" >/dev/null
    else
      a2dismod "$MOD" >/dev/null
    fi
    apache2ctl configtest >/tmp/hostvim-apache-test.log 2>&1 || { cat /tmp/hostvim-apache-test.log; exit 1; }
    systemctl reload apache2 >/dev/null 2>&1 || true
    if a2query -m "$MOD" 2>/dev/null | grep -q "enabled"; then
      echo "enabled"
    else
      echo "disabled"
    fi
    ;;
  nginx-config-get)
    SCOPE="${ARG1:-main}"
    P="$(nginx_scope_path "$SCOPE")" || { echo "invalid scope" >&2; exit 1; }
    [[ -f "$P" ]] || { echo "config file not found: $P" >&2; exit 1; }
    cat "$P"
    ;;
  nginx-config-set)
    SCOPE="${ARG1:-main}"
    SRC="${ARG2:-}"
    RELOAD="${ARG3:-1}"
    P="$(nginx_scope_path "$SCOPE")" || { echo "invalid scope" >&2; exit 1; }
    [[ -n "$SRC" && -f "$SRC" ]] || { echo "temp config source missing" >&2; exit 1; }
    BACKUP="$(mktemp)"
    HAD_ORIG=0
    if [[ -f "$P" ]]; then
      HAD_ORIG=1
      cp -a "$P" "$BACKUP" || { rm -f "$BACKUP"; echo "backup failed" >&2; exit 1; }
    fi
    install -m 644 "$SRC" "$P"
    if ! nginx -t >/tmp/hostvim-nginx-test.log 2>&1; then
      if [[ "$HAD_ORIG" -eq 1 ]]; then
        install -m 644 "$BACKUP" "$P"
      else
        rm -f "$P"
      fi
      rm -f "$BACKUP"
      cat /tmp/hostvim-nginx-test.log >&2
      exit 1
    fi
    rm -f "$BACKUP"
    if [[ "$RELOAD" == "1" ]]; then
      systemctl reload nginx >/dev/null 2>&1 || true
    fi
    echo "ok"
    ;;
  mail-stack-setup)
    DOMAIN="$(sanitize_domain "$ARG1")" || { echo "invalid domain" >&2; exit 1; }
    export DEBIAN_FRONTEND=noninteractive
    echo "[1/6] apt update"
    apt-get update -y >/dev/null
    echo "[2/6] install postfix+dovecot"
    apt-get install -y postfix dovecot-imapd dovecot-pop3d >/dev/null
    echo "[3/6] enable services"
    systemctl enable --now postfix >/dev/null 2>&1 || true
    systemctl enable --now dovecot >/dev/null 2>&1 || true
    echo "[4/6] open mail ports"
    if command -v ufw >/dev/null 2>&1; then
      ufw allow 25/tcp >/dev/null 2>&1 || true
      ufw allow 465/tcp >/dev/null 2>&1 || true
      ufw allow 587/tcp >/dev/null 2>&1 || true
      ufw allow 143/tcp >/dev/null 2>&1 || true
      ufw allow 993/tcp >/dev/null 2>&1 || true
    fi
    echo "[5/6] prepare webmail placeholder vhost"
    WEBROOT="/var/www/hostvim/webmail-placeholder/${DOMAIN}"
    mkdir -p "$WEBROOT"
    cat > "${WEBROOT}/index.html" <<EOF
<!doctype html>
<html><head><meta charset="utf-8"><title>Webmail - ${DOMAIN}</title></head>
<body style="font-family:Arial,sans-serif;padding:24px">
<h2>Webmail hazirlik sayfasi</h2>
<p>Domain: <b>${DOMAIN}</b></p>
<p>IMAP: <code>mail.${DOMAIN}:993 (SSL/TLS)</code></p>
<p>SMTP: <code>mail.${DOMAIN}:587 (STARTTLS)</code></p>
<p>Bu alan gecici placeholder sayfadir. Dilerseniz Roundcube/SOGo kurabilirsiniz.</p>
</body></html>
EOF
    NCONF="/etc/nginx/sites-available/hostvim-webmail-${DOMAIN}.conf"
    cat > "$NCONF" <<EOF
server {
  listen 80;
  server_name webmail.${DOMAIN};
  root ${WEBROOT};
  index index.html;
  location / { try_files \$uri \$uri/ /index.html; }
}
EOF
    ln -sfn "$NCONF" "/etc/nginx/sites-enabled/hostvim-webmail-${DOMAIN}.conf"
    rm -f "/etc/nginx/sites-enabled/panelsar-webmail-${DOMAIN}.conf" 2>/dev/null || true
    nginx -t >/tmp/hostvim-nginx-test.log 2>&1 || { cat /tmp/hostvim-nginx-test.log; exit 1; }
    systemctl reload nginx >/dev/null 2>&1 || true
    echo "[6/6] done"
    echo "ok"
    ;;
  *)
    echo "usage: hostvim-security fail2ban-status|fail2ban-set <on|off>|fail2ban-install|fail2ban-jail-get|fail2ban-jail-set <bantime> <findtime> <maxretry>|clamav-status|clamav-set <on|off>|clamav-scan <abs-dir>|modsec-status|modsec-set <on|off>|modsec-install|apache-modules-list|apache-module-set <module> <on|off>|nginx-config-get <main|panel>|nginx-config-set <main|panel> <tmpfile> <reload:0|1>|mail-stack-setup <domain>" >&2
    exit 1
    ;;
esac
