#!/bin/bash
# Panelsar engine (www-data) tarafından sudo ile çağrılır — nginx sites-enabled symlink + reload.
set -euo pipefail

ACTION="${1:?}"
ARG="${2:?}"

case "$ACTION" in
  enable)
    CONF="$ARG"
    [[ -f "$CONF" ]] || { echo "panelsar-nginx-vhost: conf yok: $CONF" >&2; exit 1; }
    [[ "$CONF" =~ ^/var/www/[^/]+/data/vhosts/panelsar-[a-zA-Z0-9.-]+\.conf$ ]] || {
      echo "panelsar-nginx-vhost: izin verilmeyen conf yolu" >&2
      exit 1
    }
    BASE="$(basename "$CONF")"
    ln -sf "$CONF" "/etc/nginx/sites-enabled/${BASE}"
    nginx -t
    nginx -s reload
    ;;
  disable)
    BASE="$ARG"
    [[ "$BASE" =~ ^panelsar-[a-zA-Z0-9.-]+\.conf$ ]] || {
      echo "panelsar-nginx-vhost: geçersiz dosya adı" >&2
      exit 1
    }
    rm -f "/etc/nginx/sites-enabled/${BASE}"
    nginx -t
    nginx -s reload
    ;;
  *)
    echo "panelsar-nginx-vhost: kullanım: enable <conf-yolu> | disable <basename.conf>" >&2
    exit 1
    ;;
esac
