#!/bin/bash
# Panelsar engine (www-data) tarafından sudo ile çağrılır — /etc/php/*/fpm/php.ini okuma/yazma.
set -euo pipefail

ACTION="${1:?}"
PATH_ARG="${2:?}"

validate_path() {
  local p="$1"
  [[ "$p" =~ ^/etc/php/[0-9]+\.[0-9]+/fpm/php\.ini$ ]] || {
    echo "panelsar-php-ini: izin verilmeyen yol: $p" >&2
    exit 1
  }
}

case "$ACTION" in
  read)
    validate_path "$PATH_ARG"
    cat "$PATH_ARG"
    ;;
  write)
    validate_path "$PATH_ARG"
    TMP="$(mktemp)"
    trap 'rm -f "$TMP"' EXIT
    cat >"$TMP"
    mv -f "$TMP" "$PATH_ARG"
    trap - EXIT
    ;;
  *)
    echo "panelsar-php-ini: kullanım: read <php.ini-yolu> | write <php.ini-yolu> (içerik stdin)" >&2
    exit 1
    ;;
esac
