#!/usr/bin/env bash
# Hostvim — yalnızca beyaz listedeki paket demetlerini kurar (www-data sudo ile).
# Argüman dışı veya bilinmeyen ID reddedilir.
#
# Not (rollback): apt-get install yarım kalırsa paketler kısmen kurulu kalabilir; otomatik
# “apt geri al” burada yok (panel/engine sadece çıktı/hata döner). Gerekirse sunucuda
# apt/dpkg ile elle müdahale veya demet başına özel geri alma betikleri eklenmelidir.
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive

BUNDLE="${1:?hostvim-stack-install: bundle_id gerekli}"

run_apt() {
  apt-get update -qq
  apt-get install -y -qq "$@"
}

case "$BUNDLE" in
  php-8-3-fpm-extra)
    run_apt \
      php8.3-fpm php8.3-cli php8.3-common php8.3-mysql php8.3-mbstring php8.3-xml \
      php8.3-zip php8.3-curl php8.3-intl php8.3-bcmath php8.3-sqlite3
    systemctl enable php8.3-fpm 2>/dev/null || true
    systemctl restart php8.3-fpm 2>/dev/null || true
    ;;
  php-8-2-fpm-extra)
    run_apt \
      php8.2-fpm php8.2-cli php8.2-common php8.2-mysql php8.2-mbstring php8.2-xml \
      php8.2-zip php8.2-curl php8.2-intl php8.2-bcmath php8.2-sqlite3
    systemctl enable php8.2-fpm 2>/dev/null || true
    systemctl restart php8.2-fpm 2>/dev/null || true
    ;;
  mail-postfix-relay)
    echo "postfix postfix/main_mailer_type select Internet Site" | debconf-set-selections
    echo "postfix postfix/mailname string $(hostname -f 2>/dev/null || hostname)" | debconf-set-selections
    run_apt postfix mailutils
    systemctl enable postfix
    systemctl restart postfix
    ;;
  mail-dovecot-imap)
    run_apt dovecot-core dovecot-imapd
    systemctl enable dovecot
    systemctl restart dovecot
    ;;
  mail-opendkim)
    run_apt opendkim opendkim-tools
    systemctl enable opendkim 2>/dev/null || true
    systemctl restart opendkim 2>/dev/null || true
    ;;
  mail-stack-webmail)
    _HERE="$(cd "$(dirname "$0")" && pwd)"
    MSETUP="${_HERE}/hostvim-mail-stack-setup.sh"
    if [[ ! -f "$MSETUP" ]]; then
      MSETUP="/usr/local/sbin/hostvim-mail-stack-setup.sh"
    fi
    if [[ ! -f "$MSETUP" ]]; then
      echo "hostvim-stack-install: hostvim-mail-stack-setup.sh bulunamadı (beklenen: /usr/local/sbin/hostvim-mail-stack-setup.sh)" >&2
      exit 1
    fi
    bash "$MSETUP"
    ;;
  *)
    echo "hostvim-stack-install: bilinmeyen demet: $BUNDLE" >&2
    exit 1
    ;;
esac

echo "OK $BUNDLE"
