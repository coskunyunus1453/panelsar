# Bu dosyayı repoya GERÇEK değerlerle commit etmeyin.
# Deploy sırasında sunucuda .env oluştururken kopyalayın / Ansible şablonu kullanın.

APP_ENV=production
APP_DEBUG=false
APP_URL=https://panel.ornek.com
APP_KEY=base64:CIKTAN_URETIN_php_artisan_key_generate

# İsteğe bağlı: yönetici 2FA zorunluluğu (varsayılan kapalı)
ENFORCE_ADMIN_2FA=false

# Panel kendi DB (Laravel)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hostvim
DB_USERNAME=hostvim
DB_PASSWORD=

ENGINE_API_URL=http://127.0.0.1:9090
ENGINE_INTERNAL_KEY=
HOSTVIM_HOSTING_WEB_ROOT=/var/www/data/www

# Gerçek site veritabanı provizyonu (isteğe bağlı)
MYSQL_PROVISION_ENABLED=true
MYSQL_PROVISION_HOST=127.0.0.1
MYSQL_PROVISION_USERNAME=hostvim_provision
MYSQL_PROVISION_PASSWORD=change_me_strong

# Veritabanları sayfası harici link
PHPMYADMIN_URL=https://pma.ornek.com
